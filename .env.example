# Copy this file to .env and fill in real values before running ./deploy.sh
# .env is gitignored — never commit it.

# SSH target: "user@host" or just "host" if ~/.ssh/config sets the user.
DEPLOY_HOST=deploy@fishgame.example.com

# Absolute path on the remote where the bundle will live.
# Must match the `alias` in deploy/nginx.survivors.conf.
DEPLOY_DIR=/srv/survivors

# Public URL path the game is served at. Must end with a trailing slash and
# must match the nginx location block (default: /survivors/).
BASE_PATH=/survivors/

# Port the bun server listens on AND binds to on the host (127.0.0.1:<SERVER_PORT>).
# Change if 4000 is taken on your prod host. The rendered nginx config will
# proxy to this same port.
SERVER_PORT=4000

# Internal mongo port inside the compose network. Mongo is NOT published to
# the host — only the bun container can reach it. Change only if you have a
# specific reason; the bun server's MONGO_URL is derived from this value.
MONGO_PORT=27017

# Optional SSH overrides.
DEPLOY_SSH_PORT=22
DEPLOY_SSH_KEY=

# Optional: shown in the "Deployed → ..." line printed on success.
PUBLIC_HOST=fishgame.example.com

# Optional: override the remote restart command.
# Default: brings up mongo (no recreate) then force-recreates the server container.
# RESTART_CMD="docker compose -f docker-compose.prod.yml up -d mongo && docker compose -f docker-compose.prod.yml up -d --force-recreate --no-deps server"
